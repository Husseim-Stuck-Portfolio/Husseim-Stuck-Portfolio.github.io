      DYNAMIC VISUAL SYSTEM: Geospatial Scroll Interaction
      As people scroll down, perform zoom interpolation into Berlin grid.
      Design Constraint: linear interpolation based on scroll position.
    -->
    <script>
        // Use prefers-reduced-motion for accessibility compliance
        const motionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
        const hasReducedMotion = motionQuery.matches;

        if (!hasReducedMotion) {
            const overlay = document.getElementById('geospatial-overlay');
            const totalScrollHeight = document.body.scrollHeight - window.innerHeight;

            window.addEventListener('scroll', () => {
                const currentScrollPos = window.pageYOffset;
                const scrollPercent = (currentScrollPos / totalScrollHeight);

                // Define zoom interpolation (Starts global Earth, ends urban Berlin)
                const startScale = 1; // High global orbit view
                const endScale = 2.5; // Tighter urban grid focus
                
                // Linear interpolation formula: Start + (End - Start) * Percent
                const currentScale = startScale + (endScale - startScale) * scrollPercent;
                
                // Add slight background translation for parallax effect
                const currentTranslateY = -(scrollPercent * 10); // Shifts up slightly

                overlay.style.transform = `scale(${currentScale})`;
            });
        }
    </script>
